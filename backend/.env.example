# ── CrateDB ────────────────────────────────────────────────────────────────
CRATEDB_URL=http://localhost:4200/_sql
CRATEDB_USERNAME=crate
CRATEDB_PASSWORD=
CRATEDB_FULL_TEXT_ANALYZER=spanish
COLLECTION_NAME=teleradio_content

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://YOUR_OLLAMA_HOST:11434
OLLAMA_LLM_MODEL=glm-4.7-flash
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

# ── Gemini ─────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=YOUR_GOOGLE_AI_STUDIO_API_KEY

# ── Imágenes ───────────────────────────────────────────────────────────────
IMAGE_BASE_URL=http://YOUR_OLLAMA_HOST:11434
IMAGE_DESCRIPTION_MODEL=qwen3-vl:8b
MAX_IMAGE_DESCRIPTION_TOKENS=150
IMAGE_DESCRIPTION_TEMPERATURE=0.5
IMAGE_EMBEDDING_MODEL=clip
PNG_BASE_DIR=/path/to/images
PNG_BASE_URL=http://YOUR_HOST:8000/images

# ── Reranker ───────────────────────────────────────────────────────────────
AI_SERVER_URL=http://YOUR_RERANKER_HOST:5001
RERANKER_MODEL=qwen3rerank

# ── PDF ────────────────────────────────────────────────────────────────────
PDF_DIR=../chatbot/static
PDF_COLLECTION_TABLE_NAME=pdf_files

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_RANDOM_32_CHARS

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Misc ───────────────────────────────────────────────────────────────────
DISABLE_STREAMING=0
